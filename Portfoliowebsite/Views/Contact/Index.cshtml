@{
    ViewData["Title"] = "Contact";
}

<h1>Contact</h1>

<form id="contactForm" asp-action="Index" method="post" novalidate>
    @Html.AntiForgeryToken()
    <div class="hp">
        <label for="website">Laat dit veld leeg</label>
        <input type="text" id="website" name="website" value="" />
    </div>
    <div>
        <label for="Name">Naam</label>
        <input id="Name" name="Name" placeholder="Naam" required />
        <div id="nameErr" class="error"></div>
    </div>
    <div>
        <label for="Email">E-mail</label>
        <input id="Email" name="Email" type="email" placeholder="naam@domein.nl" required />
        <div id="emailErr" class="error"></div>
    </div>
    <div>
        <label for="Subject">Onderwerp</label>
        <input id="Subject" name="Subject" placeholder="Onderwerp" />
    </div>
    <div>
        <label for="Message">Bericht</label>
        <textarea id="Message" name="Message" rows="5" required></textarea>
        <div id="msgErr" class="error"></div>
    </div>
        <button type="submit" class="send-button" id="sendBtn">
            Versturen
        </button>
</form> 